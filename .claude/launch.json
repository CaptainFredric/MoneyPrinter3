{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ContentForge API (Flask dev)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["scripts/api_prototype.py"],
      "port": 8081
    },
    {
      "name": "ContentForge API (Gunicorn)",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["deploy.wsgi:app", "--bind", "0.0.0.0:8000", "--workers", "1", "--timeout", "120"],
      "port": 8000
    },
    {
      "name": "Ollama LLM server",
      "runtimeExecutable": "ollama",
      "runtimeArgs": ["serve"],
      "port": 11434
    }
  ]
}
