              }
            }
          }
        }
      }
    },
    "/v1/thread_outline": {
      "post": {
        "summary": "Generate Twitter Thread Outline",
        "description": "Generate a complete Twitter thread outline for any topic. Returns a hook tweet (scroll-stopping opener), numbered body tweets with key insights, and a CTA closing tweet — all ready to post. Configurable tweet count (3-10) and tone.",
        "operationId": "threadOutline",
        "tags": ["AI Content Generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
