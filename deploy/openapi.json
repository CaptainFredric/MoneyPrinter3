{
  "openapi": "3.0.3",
  "info": {
    "title": "ContentForge",
    "description": "AI-powered content toolkit for creators, marketers, and developers. Score headlines instantly, score tweet drafts before posting, score LinkedIn posts for reach and engagement, generate scroll-stopping hooks, improve weak headlines with AI, rewrite text for any platform, get tweet ideas for any niche, generate full 7-day content calendars, build viral Twitter thread outlines, and generate optimized social media bios.",
    "version": "1.0.0",
    "contact": {
      "name": "Aden Cisneros",
      "email": "captainarmoreddude@gmail.com"
    }
  },
  "servers": [
    {
      "url": "https://contentforge-api-lpp9.onrender.com",
      "description": "Production"
    }
  ],
  "tags": [
    {"name": "Content Analysis", "description": "Instant heuristic scoring — zero latency, no AI token cost"},
    {"name": "AI Content Generation", "description": "AI-powered endpoints for generating and improving content"},
    {"name": "System", "description": "Health and service status"}
  ],
  "components": {
    "headers": {
      "X-RateLimit-Limit": {
        "description": "Maximum requests per minute for your plan.",
        "schema": {"type": "integer"}
      },
      "X-RateLimit-Remaining": {
        "description": "Requests remaining in the current 60-second window.",
        "schema": {"type": "integer"}
      },
      "X-RateLimit-Window": {
        "description": "Rate limit window duration.",
        "schema": {"type": "string", "example": "60s"}
      }
    }
  },
  "paths": {
    "/v1/score_tweet": {
      "post": {
        "summary": "Score a Tweet Draft",
        "description": "Score any tweet draft 0-100 for engagement potential before you post. Heuristic analysis — instant, no AI needed. Evaluates character count, hashtag usage, emoji presence, power words, and readability. Returns a grade (A-D) plus actionable improvement tips.",
        "operationId": "scoreTweet",
        "tags": ["Content Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "maxLength": 1000,
                    "description": "The tweet draft text to score",
                    "example": "Built an API in 48 hours. It made $500 last month 💸 Here's how: #indiehacker #buildinpublic"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tweet score result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {"type": "string"},
                    "score": {"type": "integer", "minimum": 0, "maximum": 100},
                    "grade": {"type": "string", "enum": ["A", "B", "C", "D"]},
                    "char_count": {"type": "integer"},
                    "word_count": {"type": "integer"},
                    "hashtag_count": {"type": "integer"},
                    "hashtags": {"type": "array", "items": {"type": "string"}},
                    "mention_count": {"type": "integer"},
                    "emoji_count": {"type": "integer"},
                    "has_url": {"type": "boolean"},
                    "power_words_found": {"type": "array", "items": {"type": "string"}},
                    "suggestions": {"type": "array", "items": {"type": "string"}}
                  }
                },
                "example": {
                  "text": "Built an API in 48 hours. It made $500 last month 💸 Here's how: #indiehacker #buildinpublic",
                  "score": 83,
                  "grade": "A",
                  "char_count": 91,
                  "word_count": 16,
                  "hashtag_count": 2,
                  "hashtags": ["#indiehacker", "#buildinpublic"],
                  "mention_count": 0,
                  "emoji_count": 1,
                  "has_url": false,
                  "power_words_found": ["hack"],
                  "suggestions": ["Try starting with a number or a question for a stronger hook."]
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid text parameter",
            "content": {
              "application/json": {
                "schema": {"type": "object", "properties": {"error": {"type": "string"}}},
                "example": {"error": "missing 'text' parameter"}
              }
            }
          },
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/v1/score_linkedin_post": {
      "post": {
        "summary": "Score a LinkedIn Post Draft",
        "description": "Score any LinkedIn post draft 0-100 for reach and engagement before you publish. Heuristic analysis, instant, no AI needed. Evaluates post length, hook strength (first paragraph preview), paragraph structure, hashtag count, list/bullet detection, call-to-action presence, URL penalty, emoji usage, and power words. Returns a grade (A-F) plus actionable improvement tips tailored to LinkedIn best practices.",
        "operationId": "scoreLinkedInPost",
        "tags": ["Content Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["post"],
                "properties": {
                  "post": {
                    "type": "string",
                    "maxLength": 5000,
                    "description": "The LinkedIn post draft text to score",
                    "example": "I spent 3 years building tools nobody used.\n\nThen I changed one thing: I started scoring my own content before posting.\n\nHere is what I learned:\n\n- Your hook decides everything (keep it under 150 chars)\n- Short paragraphs get 2x more read-throughs\n- A question at the end doubles your comments\n\nThe result? 4x more engagement in 2 months.\n\nWhat is one thing you changed that boosted your reach?\n\n#contentcreation #linkedin #buildinpublic"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "LinkedIn post score result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {"type": "string"},
                    "platform": {"type": "string", "enum": ["linkedin"]},
                    "score": {"type": "integer", "minimum": 0, "maximum": 100},
                    "grade": {"type": "string", "enum": ["A", "B", "C", "D", "F"]},
                    "char_count": {"type": "integer"},
                    "word_count": {"type": "integer"},
                    "paragraph_count": {"type": "integer"},
                    "avg_paragraph_length": {"type": "integer"},
                    "hook_length": {"type": "integer"},
                    "hook_preview": {"type": "string", "description": "First 150 chars of the opening paragraph"},
                    "has_list": {"type": "boolean"},
                    "list_items_detected": {"type": "integer"},
                    "hashtag_count": {"type": "integer"},
                    "hashtags": {"type": "array", "items": {"type": "string"}},
                    "mention_count": {"type": "integer"},
                    "emoji_count": {"type": "integer"},
                    "has_url": {"type": "boolean"},
                    "url_penalty_applied": {"type": "boolean", "description": "True if an external URL was found (LinkedIn suppresses these)"},
                    "has_cta": {"type": "boolean", "description": "True if a call-to-action phrase was detected near the end"},
                    "has_question_at_end": {"type": "boolean"},
                    "power_words_found": {"type": "array", "items": {"type": "string"}},
                    "suggestions": {"type": "array", "items": {"type": "string"}}
                  }
                },
                "example": {
                  "text": "I spent 3 years building tools nobody used...",
                  "platform": "linkedin",
                  "score": 88,
                  "grade": "A",
                  "char_count": 520,
                  "word_count": 82,
                  "paragraph_count": 6,
                  "avg_paragraph_length": 87,
                  "hook_length": 48,
                  "hook_preview": "I spent 3 years building tools nobody used.",
                  "has_list": true,
                  "list_items_detected": 3,
                  "hashtag_count": 3,
                  "hashtags": ["#contentcreation", "#linkedin", "#buildinpublic"],
                  "mention_count": 0,
                  "emoji_count": 0,
                  "has_url": false,
                  "url_penalty_applied": false,
                  "has_cta": false,
                  "has_question_at_end": true,
                  "power_words_found": ["changed", "learned"],
                  "suggestions": ["Add 1-2 emojis to break up the text and draw the eye."]
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid post parameter",
            "content": {
              "application/json": {
                "schema": {"type": "object", "properties": {"error": {"type": "string"}}},
                "example": {"error": "missing 'post' parameter. Send JSON body: {\"post\": \"your linkedin post text\"}"}
              }
            }
          },
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/v1/content_calendar": {
      "post": {
        "summary": "Generate a 7-Day Content Calendar",
        "description": "AI-powered content calendar generator. Give it a niche and get a ready-to-use multi-day posting plan with daily themes and pre-written post drafts. Supports Twitter, LinkedIn, and more. Ideal for content creators, social media managers, and indie hackers.",
        "operationId": "contentCalendar",
        "tags": ["AI Content Generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["niche"],
                "properties": {
                  "niche": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "Your niche or topic area",
                    "example": "indie hacking"
                  },
                  "days": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 7,
                    "default": 7,
                    "description": "Number of days to generate (1-7)"
                  },
                  "platform": {
                    "type": "string",
                    "enum": ["twitter", "linkedin", "instagram", "blog"],
                    "default": "twitter",
                    "description": "Target platform"
                  },
                  "tone": {
                    "type": "string",
                    "enum": ["engaging", "professional", "casual", "humorous"],
                    "default": "engaging",
                    "description": "Content tone"
                  }
                }
              },
              "example": {
                "niche": "indie hacking",
                "days": 3,
                "platform": "twitter",
                "tone": "engaging"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated content calendar",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "niche": {"type": "string"},
                    "platform": {"type": "string"},
                    "tone": {"type": "string"},
                    "days": {"type": "integer"},
                    "calendar": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "day": {"type": "string", "description": "Day of the week"},
                          "theme": {"type": "string", "description": "Content theme for the day"},
                          "draft": {"type": "string", "description": "Ready-to-post draft"}
                        }
                      }
                    }
                  }
                },
                "example": {
                  "niche": "indie hacking",
                  "platform": "twitter",
                  "tone": "engaging",
                  "days": 3,
                  "calendar": [
                    {"day": "Monday", "theme": "Motivation Monday", "draft": "Your first $1 online proves the model works. The next $1,000 is just systems. What's your system? #indiehackers"},
                    {"day": "Tuesday", "theme": "Tip Tuesday", "draft": "3 tools every solo founder needs: 1/ Stripe for payments 2/ Notion for docs 3/ Plausible for analytics. All under $50/mo. #buildinpublic"},
                    {"day": "Wednesday", "theme": "Story Hook", "draft": "6 months ago I had 0 users. Today I have 847. The only thing I changed: I started shipping every week. Thread 🧵"}
                  ]
                }
              }
            }
          },
          "400": {"description": "Missing niche parameter"},
          "429": {"description": "Rate limit exceeded"},
          "503": {"description": "AI generation temporarily unavailable"}
        }
      }
    },
    "/v1/improve_headline": {
      "post": {
        "summary": "Improve a Headline with AI",
        "description": "Analyze a weak headline and generate N better versions using AI. First scores the original, identifies weaknesses, then rewrites it into improved versions — each one scored and graded. Perfect for the analyze → improve workflow. Returns versions sorted by score descending.",
        "operationId": "improveHeadline",
        "tags": ["AI Content Generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "maxLength": 500,
                    "description": "The headline to improve",
                    "example": "How to make money online"
                  },
                  "count": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "default": 3,
                    "description": "Number of improved versions to generate"
                  }
                }
              },
              "example": {
                "text": "How to make money online",
                "count": 3
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Original analysis + improved versions scored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "original": {"type": "string"},
                    "original_score": {"type": "integer"},
                    "original_grade": {"type": "string"},
                    "original_suggestions": {"type": "array", "items": {"type": "string"}},
                    "improved_versions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "text": {"type": "string"},
                          "score": {"type": "integer"},
                          "grade": {"type": "string"},
                          "power_words_found": {"type": "array", "items": {"type": "string"}}
                        }
                      }
                    }
                  }
                },
                "example": {
                  "original": "How to make money online",
                  "original_score": 49,
                  "original_grade": "C",
                  "original_suggestions": ["Make the headline longer and more specific.", "Add a number for specificity (e.g. '5 ways', '$6K/mo')."],
                  "improved_versions": [
                    {"text": "Can You Really Earn $5,000 a Month Online? Discover the Secrets", "score": 100, "grade": "A", "power_words_found": ["earn", "secret", "discover"]},
                    {"text": "Unlock $6,000/month: 7 Proven Strategies for Online Success", "score": 85, "grade": "A", "power_words_found": ["proven"]},
                    {"text": "5 Lucrative Ways to Make $10K/Mo Online", "score": 80, "grade": "A", "power_words_found": []}
                  ]
                }
              }
            }
          },
          "400": {"description": "Missing text parameter"},
          "429": {"description": "Rate limit exceeded"},
          "503": {"description": "AI generation temporarily unavailable"}
        }
      }
    },
    "/v1/analyze_headline": {
      "post": {
        "summary": "Analyze & Score a Headline",
        "description": "Instantly scores any headline 0-100 with a letter grade and actionable improvement suggestions. Uses heuristic analysis (no AI) — responses are instant (<50ms). Evaluates length, power words, numbers, capitalization, punctuation, and curiosity factors.",
        "operationId": "analyzeHeadline",
        "tags": ["Content Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "maxLength": 500,
                    "description": "The headline text to analyze",
                    "example": "5 AI Tools That Print Money While You Sleep"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Headline analysis result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {"type": "string", "description": "The analyzed headline"},
                    "score": {"type": "integer", "minimum": 0, "maximum": 100, "description": "Overall headline score"},
                    "grade": {"type": "string", "enum": ["A", "B", "C", "D"], "description": "Letter grade"},
                    "length": {"type": "integer", "description": "Character count"},
                    "word_count": {"type": "integer", "description": "Word count"},
                    "has_number": {"type": "boolean", "description": "Whether the headline contains a number"},
                    "question_mark": {"type": "boolean", "description": "Whether it's a question"},
                    "power_words_found": {"type": "array", "items": {"type": "string"}, "description": "Power words detected"},
                    "caps_ratio": {"type": "number", "description": "Ratio of ALL-CAPS words"},
                    "suggestions": {"type": "array", "items": {"type": "string"}, "description": "Actionable improvement tips"}
                  }
                },
                "example": {
                  "text": "5 AI Tools That Print Money While You Sleep",
                  "score": 85,
                  "grade": "A",
                  "length": 44,
                  "word_count": 9,
                  "has_number": true,
                  "question_mark": false,
                  "power_words_found": [],
                  "caps_ratio": 0.11,
                  "suggestions": ["Add a power word (e.g. 'proven', 'secret', 'simple')."]
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid text parameter",
            "content": {
              "application/json": {
                "schema": {"type": "object", "properties": {"error": {"type": "string"}}},
                "example": {"error": "missing 'text' parameter"}
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {"type": "object", "properties": {"error": {"type": "string"}}},
                "example": {"error": "rate limit exceeded (30/min)"}
              }
            }
          }
        }
      }
    },
    "/v1/generate_hooks": {
      "post": {
        "summary": "Generate Scroll-Stopping Hooks",
        "description": "Uses AI to generate attention-grabbing hooks and headlines for any topic. Perfect for social media posts, email subject lines, ad copy, and blog titles. Choose from viral, professional, or casual styles.",
        "operationId": "generateHooks",
        "tags": ["AI Content Generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["topic"],
                "properties": {
                  "topic": {
                    "type": "string",
                    "maxLength": 300,
                    "description": "The topic to generate hooks for",
                    "example": "passive income with APIs"
                  },
                  "count": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 5,
                    "description": "Number of hooks to generate"
                  },
                  "style": {
                    "type": "string",
                    "enum": ["viral", "professional", "casual"],
                    "default": "viral",
                    "description": "Hook style/tone"
                  }
                }
              },
              "example": {
                "topic": "passive income with APIs",
                "count": 5,
                "style": "viral"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated hooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "topic": {"type": "string"},
                    "style": {"type": "string"},
                    "hooks": {"type": "array", "items": {"type": "string"}}
                  }
                },
                "example": {
                  "topic": "passive income with APIs",
                  "style": "viral",
                  "hooks": [
                    "I made $6K last month from an API I built in a weekend",
                    "The API economy is minting millionaires — here's how to join",
                    "3 APIs that earn more than my 9-to-5 salary"
                  ]
                }
              }
            }
          },
          "400": {"description": "Missing topic parameter"},
          "429": {"description": "Rate limit exceeded"},
          "503": {"description": "AI generation temporarily unavailable"}
        }
      }
    },
    "/v1/rewrite": {
      "post": {
        "summary": "Rewrite Text for Any Platform",
        "description": "AI-powered text rewriting optimized for specific platforms (Twitter, LinkedIn, email, blog) and tones (engaging, professional, casual, humorous). Automatically respects character limits for each platform.",
        "operationId": "rewriteText",
        "tags": ["AI Content Generation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "maxLength": 2000,
                    "description": "The text to rewrite",
                    "example": "I built an API and now it makes me money every month without doing anything."
                  },
                  "platform": {
                    "type": "string",
                    "enum": ["twitter", "linkedin", "email", "blog"],
                    "default": "twitter",
                    "description": "Target platform (adjusts length and style)"
                  },
                  "tone": {
                    "type": "string",
                    "enum": ["engaging", "professional", "casual", "humorous"],
                    "default": "engaging",
                    "description": "Desired tone of the rewrite"
                  }
                }
              },
              "example": {
                "text": "I built an API and now it makes me money every month without doing anything.",
                "platform": "twitter",
                "tone": "engaging"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rewritten text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "original": {"type": "string"},
                    "rewritten": {"type": "string"},
                    "platform": {"type": "string"},
                    "tone": {"type": "string"},
                    "char_count": {"type": "integer"}
                  }
                },
                "example": {
                  "original": "I built an API and now it makes me money every month without doing anything.",
                  "rewritten": "Built an API on a weekend. Now it pays my rent every month while I sleep. Here's the playbook:",
                  "platform": "twitter",
                  "tone": "engaging",
                  "char_count": 89
                }
              }
            }
          },
          "400": {"description": "Missing text parameter"},
          "429": {"description": "Rate limit exceeded"},
          "503": {"description": "AI generation temporarily unavailable"}
        }
      }
    },
